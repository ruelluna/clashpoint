NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Required to create the first admin. Run `supabase status` locally and copy SERVICE_ROLE_KEY.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_DOCS_URL=
USER_DOCS_URL=
PLAYWRIGHT_PORT=3001
PLAYWRIGHT_ADMIN_EMAIL=ruelluna@gmail.com
PLAYWRIGHT_ADMIN_PASSWORD=password
# Optional dev seed (npm run seed:first-admin) — defaults match Playwright admin creds
SEED_FIRST_ADMIN_EMAIL=ruelluna@gmail.com
SEED_FIRST_ADMIN_PASSWORD=password
SEED_FIRST_ADMIN_DISPLAY_NAME=Ruel Luna
SEED_FIRST_ADMIN_UPDATE_PASSWORD=true
